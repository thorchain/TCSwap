{
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.29.6",
    "@types/bun": "1.2.20",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7",
    "lefthook": "1.12.3",
    "typescript": "5.9.2"
  },
  "name": "swapkit-monorepo",
  "packageManager": "bun@^1.2.18",
  "private": true,
  "scripts": {
    "bootstrap": "bun clean --force; bun build:ci",
    "build": "bun --filter '!@internal/docs' --elide-lines=0 build",
    "build:ci": "bun build:dts && bun --filter '!@internal/docs' build",
    "build:clean": "bun build:dts && bun --filter '!@internal/docs' --elide-lines=0 build:clean",
    "build:debug": "DEBUG=true bun build:dts && bun --filter '!@internal/docs' build",
    "build:dts": "bun ./tools/builder/dts.ts",
    "clean": "bun --filter '*' clean && rm -rf bun.lock node_modules build; bun install",
    "docs": "bun --cwd ./docs",
    "generate:tokens": "bun --filter '@swapkit/helpers' build; bun --cwd packages/tokens generate-tokens; bun lint",
    "lint": "bun biome check --write .",
    "lint:ws": "bunx sherif@latest",
    "playground:backend-bun": "bun --cwd ./playgrounds/bun-backend",
    "playground:next": "bun --cwd ./playgrounds/nextjs",
    "playground:react-bun": "bun --cwd ./playgrounds/bun-react",
    "playground:vite": "bun --cwd ./playgrounds/vite",
    "postinstall": "lefthook install; bun lint:ws",
    "publish-packages": "bun build:ci && bun ./tools/builder/set-versions.ts && bun changeset publish",
    "test": "bun --filter '*' --elide-lines=0 test",
    "test:ci": "bun --filter '*' test:ci",
    "test:coverage": "bun --filter '*' --elide-lines=0 test:ci",
    "type-check": "bun --filter '*' --elide-lines=0 type-check",
    "type-check:ci": "bun --filter '*' type-check",
    "type-check:go": "bun --filter '*' type-check:go",
    "version-bump": "bun changeset version; bun install"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "bigint-buffer",
    "blake-hash",
    "bufferutil",
    "core-js-pure",
    "esbuild",
    "keccak",
    "lefthook",
    "protobufjs",
    "secp256k1",
    "sharp",
    "tiny-secp256k1",
    "usb"
  ],
  "workspaces": ["packages/*", "playgrounds/*", "tools/*", "docs"]
}
