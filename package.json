{
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.29.5",
    "@types/bun": "1.2.18",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "lefthook": "1.11.16",
    "react": "19.1.0",
    "typescript": "5.8.3"
  },
  "name": "swapkit-monorepo",
  "packageManager": "bun@^1.2.18",
  "private": true,
  "scripts": {
    "bootstrap": "bun clean; bun install --force; bun run build",
    "build": "bun --filter '!@internal/docs' --elide-lines=0 build",
    "build:clean": "bun --filter '!@internal/docs' --elide-lines=0 build:clean",
    "build:ci": "bun --filter '!@internal/docs' build",
    "build:debug": "DEBUG=true bun --filter '!@internal/docs' build",
    "clean": "bun --filter '*' clean && rm -rf bun.lock node_modules build; bun install",
    "docs": "bun --cwd ./docs",
    "generate:tokens": "bun --filter '@swapkit/helpers' build; bun --cwd packages/helpers generate-tokens; bun lint",
    "lint": "bun biome check --write .",
    "lint:ws": "bun x sherif@latest",
    "playground:bun-react": "bun --cwd ./playgrounds/bun-react",
    "playground:next": "bun --cwd ./playgrounds/nextjs",
    "playground:vite": "bun --cwd ./playgrounds/vite",
    "postinstall": "lefthook install; bun lint:ws",
    "publish-packages": "bun build:ci && bun version-bump && bun changeset publish",
    "test": "bun --filter '*' --elide-lines=0 test",
    "test:ci": "bun --filter '*' test:ci",
    "test:coverage": "bun --filter '*' --elide-lines=0 test:ci",
    "type-check": "bun --filter '*' --elide-lines=0 type-check",
    "type-check:ci": "bun --filter '*' type-check",
    "type-check:go": "bun --filter '*' type-check:go",
    "version-bump": "bun changeset version"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "bigint-buffer",
    "blake-hash",
    "bufferutil",
    "core-js-pure",
    "esbuild",
    "lefthook",
    "protobufjs",
    "keccak",
    "usb"
  ],
  "workspaces": ["packages/*", "playgrounds/*", "tools/*", "docs"],
  "patchedDependencies": {
    "starlight-openapi@0.18.0": "patches/starlight-openapi@0.18.0.patch"
  }
}
