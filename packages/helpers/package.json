{
  "author": "swapkit-oss",
  "dependencies": {
    "@swapkit/contracts": "workspace:*",
    "@swapkit/tokens": "workspace:*",
    "@swapkit/types": "workspace:*",
    "ethers": "^6.14.0",
    "ts-pattern": "^5.7.0",
    "zod": "3.25.74",
    "zustand": "^5.0.0"
  },
  "description": "SwapKit - Helpers",
  "devDependencies": {
    "@swapkit/toolboxes": "workspace:*",
    "ethers": "6.15.0",
    "ts-pattern": "5.8.0",
    "zod": "3.25.74",
    "zustand": "5.0.8"
  },
  "exports": {
    ".": { "default": "./dist/index.js", "require": "./dist/index.cjs", "types": "./dist/types/index.d.ts" },
    "./api": {
      "default": "./dist/api/index.js",
      "require": "./dist/api/index.cjs",
      "types": "./dist/types/api/index.d.ts"
    },
    "./contracts": {
      "default": "./dist/contracts.js",
      "require": "./dist/contracts.cjs",
      "types": "./dist/types/contracts.d.ts"
    },
    "./tokens": { "default": "./dist/tokens.js", "require": "./dist/tokens.cjs", "types": "./dist/types/tokens.d.ts" }
  },
  "files": ["dist/"],
  "homepage": "https://github.com/swapkit/SwapKit",
  "license": "Apache-2.0",
  "name": "@swapkit/helpers",
  "repository": { "directory": "packages/helpers", "type": "git", "url": "git+https://github.com/swapkit/SwapKit.git" },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "generate-tokens": "bun --bun ./fetchTokenLists.ts",
    "test": "bun test",
    "test:ci": "bun test --coverage",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "4.3.0"
}
