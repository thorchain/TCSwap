{
  "author": "swapkit-oss",
  "dependencies": {
    "zod": "3.24.1",
    "zustand": "5.0.3"
  },
  "description": "SwapKit - Helpers",
  "devDependencies": {
    "@swapkit/toolboxes": "workspace:*"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    },
    "./api": {
      "default": "./dist/api/index.js",
      "require": "./dist/api/index.cjs",
      "types": "./src/api/index.ts"
    },
    "./contracts": {
      "default": "./dist/contracts/index.js",
      "require": "./dist/contracts/index.cjs",
      "types": "./src/contracts/index.ts"
    },
    "./tokens": {
      "default": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs",
      "types": "./src/tokens/index.ts"
    }
  },
  "files": ["src/", "dist/"],
  "homepage": "https://github.com/thorswap/SwapKit",
  "license": "Apache-2.0",
  "name": "@swapkit/helpers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thorswap/SwapKit.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "lint": "biome check --write ./src",
    "generate-tokens": "bun --bun ./fetchTokenLists.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "version": "2.4.3"
}
