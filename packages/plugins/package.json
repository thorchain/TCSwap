{
  "author": "swapkit-oss",
  "dependencies": {
    "@polkadot/keyring": "13.5.3",
    "@polkadot/util": "13.5.3",
    "@solana/web3.js": "1.98.2",
    "@swapkit/helpers": "workspace:*",
    "@swapkit/toolboxes": "workspace:*",
    "ts-pattern": "5.7.1"
  },
  "description": "SwapKit Plugin - ChainFlip",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    },
    "./chainflip": {
      "default": "./dist/chainflip/index.js",
      "require": "./dist/chainflip/index.cjs",
      "types": "./src/chainflip/index.ts"
    },
    "./evm": {
      "default": "./dist/evm/index.js",
      "require": "./dist/evm/index.cjs",
      "types": "./src/evm/index.ts"
    },
    "./near": {
      "default": "./dist/near/index.js",
      "require": "./dist/near/index.cjs",
      "types": "./src/near/index.ts"
    },
    "./radix": {
      "default": "./dist/radix/index.js",
      "require": "./dist/radix/index.cjs",
      "types": "./src/radix/index.ts"
    },
    "./solana": {
      "default": "./dist/solana/index.js",
      "require": "./dist/solana/index.cjs",
      "types": "./src/solana/index.ts"
    },
    "./thorchain": {
      "default": "./dist/thorchain/index.js",
      "require": "./dist/thorchain/index.cjs",
      "types": "./src/thorchain/index.ts"
    }
  },
  "files": ["src/", "dist/"],
  "homepage": "https://github.com/thorswap/SwapKit",
  "license": "Apache-2.0",
  "name": "@swapkit/plugins",
  "repository": {
    "directory": "packages/plugins",
    "type": "git",
    "url": "git+https://github.com/thorswap/SwapKit.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "1.0.0-beta.34"
}
