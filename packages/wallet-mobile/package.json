{
  "author": "swapkit-oss",
  "dependencies": { "@uswap/helpers": "workspace:*", "@uswap/toolboxes": "workspace:*" },
  "description": "USwap - Wallet Mobile",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": ["dist/", "src/"],
  "homepage": "https://github.com/horizontalsystems/USwap",
  "license": "Apache-2.0",
  "name": "@uswap/wallet-mobile",
  "repository": {
    "directory": "packages/wallet-mobile",
    "type": "git",
    "url": "git+https://github.com/horizontalsystems/USwap.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "test": "echo 'bun test'",
    "test:ci": "echo 'bun test --coverage'",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "4.0.57"
}
