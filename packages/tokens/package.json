{
  "author": "swapkit-oss",
  "dependencies": {
    "@swapkit/helpers": "workspace:*",
    "@swapkit/toolboxes": "workspace:*",
    "@swapkit/wallets": "workspace:*"
  },
  "description": "SwapKit - Tokens",
  "exports": {
    ".": { "import": "./dist/index.js", "require": "./dist/index.cjs", "types": "./dist/types/index.d.ts" }
  },
  "files": ["dist/"],
  "homepage": "https://github.com/swapkit/SwapKit",
  "license": "Apache-2.0",
  "name": "@swapkit/tokens",
  "repository": { "directory": "packages/tokens", "type": "git", "url": "git+https://github.com/swapkit/SwapKit.git" },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "generate-tokens": "bun --bun ./fetchTokenLists.ts",
    "test": "echo 'bun test'",
    "test:ci": "echo 'bun test --coverage'",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "4.0.19"
}
