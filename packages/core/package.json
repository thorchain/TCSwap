{
  "author": "swapkit-oss",
  "dependencies": {
    "@tcswap/helpers": "4.5.15",
    "@tcswap/plugins": "4.2.15",
    "@tcswap/toolboxes": "4.3.15",
    "@tcswap/wallets": "4.3.16",
    "ts-pattern": "^5.9.0"
  },
  "description": "USwap - Core",
  "devDependencies": { "ts-pattern": "5.9.0" },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": ["dist/", "src/"],
  "homepage": "https://github.com/thorchain/TCSwap",
  "license": "Apache-2.0",
  "name": "@tcswap/core",
  "repository": { "directory": "packages/core", "type": "git", "url": "git+https://github.com/thorchain/TCSwap.git" },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "test": "echo 'bun test'",
    "test:ci": "echo 'bun test --coverage'",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "4.1.16"
}
