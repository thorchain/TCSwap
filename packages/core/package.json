{
  "author": "swapkit-oss",
  "dependencies": {
    "@swapkit/helpers": "workspace:*",
    "@swapkit/toolboxes": "workspace:*"
  },
  "description": "SwapKit - Core",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    }
  },
  "files": ["src/", "dist/"],
  "homepage": "https://github.com/swapkit/SwapKit",
  "license": "Apache-2.0",
  "name": "@swapkit/core",
  "repository": {
    "directory": "packages/core",
    "type": "git",
    "url": "git+https://github.com/swapkit/SwapKit.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "test": "echo 'bun test'",
    "test:ci": "bun test --coverage",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "4.0.0-beta.41"
}
