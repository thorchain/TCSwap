{
  "author": "swapkit-oss",
  "dependencies": {
    "@swapkit/core": "workspace:*",
    "@swapkit/plugins": "workspace:*",
    "@swapkit/toolboxes": "workspace:*",
    "@swapkit/wallets": "workspace:*"
  },
  "description": "SwapKit - SDK",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    }
  },
  "files": ["src/", "dist/"],
  "homepage": "https://github.com/thorswap/SwapKit",
  "license": "Apache-2.0",
  "name": "@swapkit/sdk",
  "repository": {
    "directory": "packages/sdk",
    "type": "git",
    "url": "git+https://github.com/thorswap/SwapKit.git"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "3.0.0-beta.15"
}
