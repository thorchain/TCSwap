{
  "author": "swapkit-oss",
  "dependencies": {
    "@tcswap/core": "4.1.16",
    "@tcswap/helpers": "4.5.15",
    "@tcswap/plugins": "4.2.15",
    "@tcswap/server": "4.0.59",
    "@tcswap/toolboxes": "4.3.15",
    "@tcswap/wallets": "4.3.16"
  },
  "description": "USwap - SDK",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./core": {
      "bun": "./src/core.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/types/core.d.ts"
    },
    "./plugins": {
      "bun": "./src/plugins.ts",
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.cjs",
      "types": "./dist/types/plugins.d.ts"
    },
    "./server": {
      "bun": "./src/server.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs",
      "types": "./dist/types/server.d.ts"
    },
    "./wallets": {
      "bun": "./src/wallets.ts",
      "import": "./dist/wallets.js",
      "require": "./dist/wallets.cjs",
      "types": "./dist/types/wallets.d.ts"
    }
  },
  "files": ["dist/", "src/"],
  "homepage": "https://github.com/thorchain/TCSwap",
  "license": "Apache-2.0",
  "name": "@tcswap/sdk",
  "repository": { "directory": "packages/sdk", "type": "git", "url": "git+https://github.com/thorchain/TCSwap.git" },
  "scripts": {
    "build": "bun run ./build.ts",
    "build:clean": "rm -rf dist && bun run ./build.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "type-check": "bun tsc --noEmit",
    "type-check:go": "tsgo"
  },
  "type": "module",
  "version": "4.2.16"
}
