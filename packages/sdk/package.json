{
  "author": "swapkit-oss",
  "dependencies": {
    "@swapkit/core": "4.0.0-beta.52",
    "@swapkit/plugins": "4.0.0-beta.51",
    "@swapkit/toolboxes": "4.0.0-beta.51",
    "@swapkit/wallets": "4.0.0-beta.55"
  },
  "description": "SwapKit - SDK",
  "exports": {
    ".": {
